direction: down

vars: {
  d2-config: {
    theme-id: 0
    pad: 20
    layout-engine: elk
  }
}

cli: "prax CLI / REPL" {
  shape: rectangle
  style: {
    fill: "#667eea"
    stroke: "#667eea"
    font-color: "#ffffff"
    border-radius: 12
    font-size: 20
    bold: true
  }
}

runtime: Agent Runtime {
  style: {
    fill: "#f7f8fc"
    stroke: "#e2e8f0"
    border-radius: 16
    font-size: 15
    bold: true
    font-color: "#4a5568"
  }

  loop: "Agent Loop · 25 iter max · circuit breaker" {
    shape: rectangle
    style: {
      fill: "#fa709a"
      stroke: "#fa709a"
      font-color: "#ffffff"
      border-radius: 10
      font-size: 15
      bold: true
    }
  }

  middleware: Middleware {
    direction: right
    style: {
      fill: "#eef2ff"
      stroke: "#c7d2fe"
      border-radius: 10
      font-size: 13
      bold: true
      font-color: "#4a5568"
    }

    guard: Permission\nGuard {
      style: {
        fill: "#667eea"
        stroke: "#667eea"
        font-color: "#ffffff"
        border-radius: 8
        font-size: 13
        bold: true
      }
    }
    cache: Cache {
      style: {
        fill: "#667eea"
        stroke: "#667eea"
        font-color: "#ffffff"
        border-radius: 8
        font-size: 13
        bold: true
      }
    }
    inject: Context\nInject {
      style: {
        fill: "#667eea"
        stroke: "#667eea"
        font-color: "#ffffff"
        border-radius: 8
        font-size: 13
        bold: true
      }
    }
    extract: Memory\nExtract {
      style: {
        fill: "#667eea"
        stroke: "#667eea"
        font-color: "#ffffff"
        border-radius: 8
        font-size: 13
        bold: true
      }
    }
    qg: Quality\nGate {
      style: {
        fill: "#30cfd0"
        stroke: "#30cfd0"
        font-color: "#ffffff"
        border-radius: 8
        font-size: 13
        bold: true
      }
    }

    guard -> cache -> inject -> extract -> qg
  }

  loop -> middleware
}

tools: Tools {
  direction: right
  style: {
    fill: "#f7f8fc"
    stroke: "#e2e8f0"
    border-radius: 16
    font-size: 15
    bold: true
    font-color: "#4a5568"
  }

  rw: "Read · Edit · Grep · Glob" {
    style: {
      fill: "#f093fb"
      stroke: "#f093fb"
      font-color: "#ffffff"
      border-radius: 8
      font-size: 14
      bold: true
    }
  }
  shell: "Bash · Git · Sandbox" {
    style: {
      fill: "#f093fb"
      stroke: "#f093fb"
      font-color: "#ffffff"
      border-radius: 8
      font-size: 14
      bold: true
    }
  }
  vc: VerifyCommand {
    style: {
      fill: "#fa709a"
      stroke: "#fa709a"
      font-color: "#ffffff"
      border-radius: 8
      font-size: 14
      bold: true
    }
  }
  mcp: "MCP Tools" {
    style: {
      fill: "#f093fb"
      stroke: "#f093fb"
      font-color: "#ffffff"
      border-radius: 8
      font-size: 14
      bold: true
    }
  }
}

infra: Infrastructure {
  direction: right
  style: {
    fill: "#f7f8fc"
    stroke: "#e2e8f0"
    border-radius: 16
    font-size: 15
    bold: true
    font-color: "#4a5568"
  }

  models: "Multi-Model Router\nClaude · GPT · GLM" {
    shape: rectangle
    style: {
      fill: "#667eea"
      stroke: "#667eea"
      font-color: "#ffffff"
      border-radius: 10
      font-size: 14
      bold: true
    }
  }

  memory: "Memory\nJSON · SQLite · Vector" {
    shape: cylinder
    style: {
      fill: "#a8edea"
      stroke: "#a8edea"
      font-color: "#2d3748"
      font-size: 14
      bold: true
    }
  }

  sessions: "Sessions\nHistory · Replay" {
    shape: rectangle
    style: {
      fill: "#fee140"
      stroke: "#fee140"
      font-color: "#2d3748"
      border-radius: 10
      font-size: 14
      bold: true
    }
  }
}

cli -> runtime
runtime -> tools

runtime.loop -> infra.models {
  style.stroke-dash: 5
  style.stroke: "#cbd5e0"
  style.stroke-width: 2
}
runtime.loop -> infra.memory {
  style.stroke-dash: 5
  style.stroke: "#cbd5e0"
  style.stroke-width: 2
}
runtime.loop -> infra.sessions {
  style.stroke-dash: 5
  style.stroke: "#cbd5e0"
  style.stroke-width: 2
}
