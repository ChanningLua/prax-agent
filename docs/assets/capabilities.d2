direction: right

vars: {
  d2-config: {
    theme-id: 0
    pad: 20
    layout-engine: elk
  }
}

grid-rows: 1

verify: "🎯 Verification-First" {
  shape: rectangle
  style: {
    fill: "#667eea"
    stroke: "#667eea"
    font-color: "#ffffff"
    border-radius: 16
    font-size: 18
    bold: true
  }
}

