direction: down

vars: {
  d2-config: {
    theme-id: 0
    pad: 20
    layout-engine: elk
  }
}

title: Integration Paths {
  near: top-center
  shape: text
  style: {
    font-size: 22
    bold: true
    font-color: "#2d3748"
  }
}

pathA: Path A: Native Runtime {
  style: {
    fill: "#f7f8fc"
    stroke: "#e2e8f0"
    border-radius: 16
    font-size: 16
    bold: true
    font-color: "#4a5568"
  }

  cli: "CLI Entry\nprax \"task\"" {
    shape: rectangle
    style: {
      fill: "#667eea"
      stroke: "#667eea"
      font-color: "#ffffff"
      border-radius: 12
      font-size: 15
      bold: true
    }
  }

  loop: "Agent Loop\nRalph · Sisyphus" {
    shape: rectangle
    style: {
      fill: "#fa709a"
      stroke: "#fa709a"
      font-color: "#ffffff"
      border-radius: 12
      font-size: 15
      bold: true
    }
  }

  tools: "Tools\nRead · Edit · Bash\nVerifyCommand" {
    shape: rectangle
    style: {
      fill: "#f093fb"
      stroke: "#f093fb"
      font-color: "#ffffff"
      border-radius: 10
      font-size: 14
      bold: true
    }
  }

  cli -> loop
  loop -> tools
}

pathB: Path B: Claude Code Integration {
  style: {
    fill: "#f7f8fc"
    stroke: "#e2e8f0"
    border-radius: 16
    font-size: 16
    bold: true
    font-color: "#4a5568"
  }

  ide: "IDE Entry\nClaude Code" {
    shape: rectangle
    style: {
      fill: "#667eea"
      stroke: "#667eea"
      font-color: "#ffffff"
      border-radius: 12
      font-size: 15
      bold: true
    }
  }

  mcp: "MCP Servers\nprax-memory\nprax-thinking" {
    shape: rectangle
    style: {
      fill: "#30cfd0"
      stroke: "#30cfd0"
      font-color: "#ffffff"
      border-radius: 12
      font-size: 15
      bold: true
    }
  }

  hooks: "Hooks\nSessionStart\nPreToolUse · Stop" {
    shape: rectangle
    style: {
      fill: "#fee140"
      stroke: "#fee140"
      font-color: "#2d3748"
      border-radius: 12
      font-size: 15
      bold: true
    }
  }

  agentloop: "Agent Loop" {
    shape: rectangle
    style: {
      fill: "#fa709a"
      stroke: "#fa709a"
      font-color: "#ffffff"
      border-radius: 12
      font-size: 15
      bold: true
    }
  }

  ide -> mcp
  mcp -> hooks
  hooks -> agentloop
}

shared: Shared Infrastructure {
  direction: right
  style: {
    fill: "#f7f8fc"
    stroke: "#e2e8f0"
    border-radius: 16
    font-size: 16
    bold: true
    font-color: "#4a5568"
  }

  llm: "LLM Router\nClaude · GPT · GLM" {
    shape: rectangle
    style: {
      fill: "#667eea"
      stroke: "#667eea"
      font-color: "#ffffff"
      border-radius: 10
      font-size: 14
      bold: true
    }
  }

  memory: "Memory\nJSON · SQLite · Vector" {
    shape: cylinder
    style: {
      fill: "#a8edea"
      stroke: "#a8edea"
      font-color: "#2d3748"
      font-size: 14
      bold: true
    }
  }

  toolreg: "Tools Registry\n25+ built-in tools" {
    shape: rectangle
    style: {
      fill: "#f093fb"
      stroke: "#f093fb"
      font-color: "#ffffff"
      border-radius: 10
      font-size: 14
      bold: true
    }
  }
}

pathA.loop -> shared.llm {
  style.stroke-dash: 5
  style.stroke: "#cbd5e0"
  style.stroke-width: 2
}
pathA.loop -> shared.memory {
  style.stroke-dash: 5
  style.stroke: "#cbd5e0"
  style.stroke-width: 2
}
pathA.tools -> shared.toolreg {
  style.stroke-dash: 5
  style.stroke: "#cbd5e0"
  style.stroke-width: 2
}

pathB.agentloop -> shared.llm {
  style.stroke-dash: 5
  style.stroke: "#cbd5e0"
  style.stroke-width: 2
}
pathB.agentloop -> shared.memory {
  style.stroke-dash: 5
  style.stroke: "#cbd5e0"
  style.stroke-width: 2
}
pathB.agentloop -> shared.toolreg {
  style.stroke-dash: 5
  style.stroke: "#cbd5e0"
  style.stroke-width: 2
}
